{
  "name": "@create-nxy/monorepo",
  "version": "1.0.0",
  "description": "",
  "author": "xy",
  "license": "MIT",
  "scripts": {
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "docs:dev": "pnpm run -C docs docs:dev",
    "docs:build": "pnpm run -C docs docs:build",
    "play:dev": "pnpm run -C playground dev",
    "play:build": "pnpm run -C playground build",
    "build": "run-p design:build use:build tool:build preset:build icon:build cli:build",
    "design:release": "pnpm run -C packages/build-system design:release",
    "design:build": "pnpm run -C packages/build-system design:build",
    "design:publish": "pnpm run -C packages/build-system design:publish",
    "use:release": "pnpm run -C packages/build-system use:release",
    "use:build": "pnpm run -C packages/build-system use:build",
    "use:publish": "pnpm run -C packages/build-system use:publish",
    "tool:release": "pnpm run -C packages/build-system tool:release",
    "tool:build": "pnpm run -C packages/build-system tool:build",
    "tool:publish": "pnpm run -C packages/build-system tool:publish",
    "preset:release": "pnpm run -C packages/build-system preset:release",
    "preset:build": "pnpm run -C packages/build-system preset:build",
    "preset:publish": "pnpm run -C packages/build-system preset:publish",
    "icon:optimize": "pnpm run -C packages/icons/svg optimize",
    "icon:generate": "pnpm run -C packages/build-system icon:generate",
    "icon:release": "pnpm run -C packages/build-system icon:release",
    "icon:build": "pnpm run -C packages/build-system icon:build",
    "icon:publish": "pnpm run -C packages/build-system icon:publish",
    "cli:release": "pnpm run -C packages/build-system cli:release",
    "cli:build": "pnpm run -C packages/build-system cli:build",
    "cli:publish": "pnpm run -C packages/build-system cli:publish",
    "lint:style": "stylelint \"./**/*.{css,less,vue,html}\" --fix",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/node": "^25.9.1",
    "@unocss/eslint-plugin": "^66.7.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.1",
    "eslint-plugin-format": "^2.0.1",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.15",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "sass": "^1.100.0",
    "stylelint": "^17.12.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-scss": "^7.1.1",
    "typescript": "^6.0.3",
    "unocss": "^66.7.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue": "^3.5.35",
    "vue-tsc": "^3.3.3"
  },
  "lint-staged": {
    "*.{vue,js,ts,tsx,jsx}": [
      "eslint . --fix"
    ]
  }
}
