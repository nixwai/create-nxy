{
  "name": "@create-nxy/monorepo",
  "version": "1.0.0",
  "packageManager": "pnpm@11.15.1",
  "description": "",
  "author": "xy",
  "license": "MIT",
  "scripts": {
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "docs:dev": "pnpm run -C docs docs:dev",
    "docs:build": "pnpm run -C docs docs:build",
    "play:dev": "pnpm run -C playground dev",
    "play:build": "pnpm run -C playground build",
    "build": "pnpm run -C tooling build",
    "design:release": "pnpm run -C tooling design:release",
    "design:build": "pnpm run -C tooling design:build",
    "design:publish": "pnpm run -C tooling design:publish",
    "use:release": "pnpm run -C tooling use:release",
    "use:build": "pnpm run -C tooling use:build",
    "use:publish": "pnpm run -C tooling use:publish",
    "tool:release": "pnpm run -C tooling tool:release",
    "tool:build": "pnpm run -C tooling tool:build",
    "tool:publish": "pnpm run -C tooling tool:publish",
    "preset:release": "pnpm run -C tooling preset:release",
    "preset:build": "pnpm run -C tooling preset:build",
    "preset:publish": "pnpm run -C tooling preset:publish",
    "icon:optimize": "pnpm run -C packages/icons/svg optimize",
    "icon:generate": "pnpm run -C tooling icon:generate",
    "icon:release": "pnpm run -C tooling icon:release",
    "icon:build": "pnpm run -C tooling icon:build",
    "icon:publish": "pnpm run -C tooling icon:publish",
    "cli:release": "pnpm run -C tooling cli:release",
    "cli:build": "pnpm run -C tooling cli:build",
    "cli:publish": "pnpm run -C tooling cli:publish",
    "lint:style": "stylelint \"./**/*.{css,less,vue,html}\"",
    "lint:style-fix": "stylelint \"./**/*.{css,less,vue,html}\" --fix",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-format": "^2.0.1",
    "happy-dom": "^20.11.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "postcss": "^8.5.20",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "sass": "^1.101.0",
    "stylelint": "^17.14.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-scss": "^7.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{vue,js,ts,tsx,jsx}": [
      "eslint . --fix"
    ]
  }
}
